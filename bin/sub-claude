#!/usr/bin/env bash
set -euo pipefail

# Resolve lib dir: prefer sibling lib/ next to bin/, fall back to ~/.local/lib/
_bin_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SUB_CLAUDE_LIB="${_bin_dir}/../lib/sub-claude"
if [[ ! -d "$SUB_CLAUDE_LIB" ]]; then
  SUB_CLAUDE_LIB="$HOME/.local/lib/sub-claude"
fi
if [[ ! -d "$SUB_CLAUDE_LIB" ]]; then
  echo "sub-claude: lib dir not found (tried ${_bin_dir}/../lib/sub-claude and ~/.local/lib/sub-claude)" >&2
  exit 1
fi
SUB_CLAUDE_LIB="$(cd "$SUB_CLAUDE_LIB" && pwd)"

# Resolve plugin dir: repo root (dev) or installed share dir.
# Exported so pool init in subprocesses can still inject --plugin-dir.
_repo_root="${_bin_dir}/.."
if [[ -f "$_repo_root/.claude-plugin/plugin.json" ]]; then
  export SUB_CLAUDE_PLUGIN_DIR="$(cd "$_repo_root" && pwd)"
elif [[ -f "$HOME/.local/share/sub-claude/.claude-plugin/plugin.json" ]]; then
  export SUB_CLAUDE_PLUGIN_DIR="$HOME/.local/share/sub-claude"
fi

# Source output parser library (standalone, no sub-claude deps)
_output_lib="${_bin_dir}/../lib/claude-output"
if [[ ! -d "$_output_lib" ]]; then
  _output_lib="$HOME/.local/lib/claude-output"
fi
if [[ -f "$_output_lib/parse.sh" ]]; then
  # shellcheck source=/dev/null
  source "$_output_lib/parse.sh"
fi
if [[ -f "$_output_lib/jsonl.sh" ]]; then
  # shellcheck source=/dev/null
  source "$_output_lib/jsonl.sh"
fi

# Source libs — core.sh first, then the rest
if [[ -f "$SUB_CLAUDE_LIB/core.sh" ]]; then
  # shellcheck source=/dev/null
  source "$SUB_CLAUDE_LIB/core.sh"
fi
for _lib in "$SUB_CLAUDE_LIB"/*.sh; do
  [[ "$(basename "$_lib")" == "core.sh" ]] && continue
  # shellcheck source=/dev/null
  source "$_lib"
done

usage() {
  cat <<'EOF'
Usage: sub-claude [-C <dir>] [-v LEVEL] <command> [args]

Global options:
  -C <dir>                Target a pool in a different project directory
  -v, --verbosity LEVEL   Output filter: response|conversation|full|raw (default: raw)
  --terminal              Output raw terminal capture instead of JSONL response

Session commands:
  start "prompt" [--block] [--timeout S]   Start a new session
  followup <id> "prompt" [--block] [--timeout S]  Continue a session
  input <id> "text"               Type text into session
  key <id> <key>                  Send special key (Escape, Enter, ...)
  capture <id>                    Capture terminal output
  result <id>                     Get final output (errors if running)
  wait [<id>] [--quiet] [--timeout S]  Wait for completion
  pin <id> [duration]             Prevent offloading (default: 120s)
  unpin <id>                      Allow offloading again
  status <id>                     Show session state
  list [--tree | --all]           Show sessions
  stop <id> | --tree | --all      Interrupt busy session(s)
  cancel <id>                     Remove from queue
  clean <id> [--force | --force-all]  Clean session + children

Pool management:
  pool init [--size N] [--idle-timeout S] [--ttl S] [--pressure-threshold N]
                                    Start root pool (default: 5 slots, 1800s idle, 7200s TTL)
  pool init --local [...]           Start project-local pool (overrides root for this project)
  pool stop                       Kill pool + tmux server
  pool status                     Show pool overview
  pool resize N                   Add or remove slots
  pool list                       List all pools across projects
  pool destroy <hash> | --all     Tear down a specific or all pools
  pool gc                         Clean up stale pool directories
  pool migrate                    Clean up old claude-pool artifacts

Custom commands:
  run <command> [args...]         Run a custom command script
  run --list                      List available commands

Debug:
  attach <id>                     Attach to tmux pane
  uuid <id>                       Show Claude UUID + slot info
EOF
}

# Parse global options before the subcommand.
export SUB_CLAUDE_VERBOSITY="${SUB_CLAUDE_VERBOSITY:-raw}"
export SUB_CLAUDE_TERMINAL="${SUB_CLAUDE_TERMINAL:-}"
while [[ "${1:-}" == -* ]]; do
  case "$1" in
    -C)
      [[ $# -ge 2 ]] || { echo "sub-claude: -C requires a directory argument" >&2; exit 1; }
      cd "$2" || { echo "sub-claude: cannot cd to '$2'" >&2; exit 1; }
      shift 2 ;;
    --verbosity|-v)
      [[ $# -ge 2 ]] || { echo "sub-claude: -v requires an argument" >&2; exit 1; }
      SUB_CLAUDE_VERBOSITY="$2"; shift 2
      case "$SUB_CLAUDE_VERBOSITY" in
        response|conversation|full|raw) ;;
        *) echo "sub-claude: invalid verbosity '$SUB_CLAUDE_VERBOSITY' (use response|conversation|full|raw)" >&2; exit 1 ;;
      esac ;;
    --terminal) SUB_CLAUDE_TERMINAL="--terminal"; shift ;;
    *) break ;;
  esac
done

resolve_pool_dir

cmd="${1:-}"
shift || true

case "$cmd" in
  start)    cmd_start "$@" ;;
  followup) cmd_followup "$@" ;;
  input)    cmd_input "$@" ;;
  key)      cmd_key "$@" ;;
  capture)  cmd_capture "$@" ;;
  result)   cmd_result "$@" ;;
  wait)     cmd_wait "$@" ;;
  pin)      cmd_pin "$@" ;;
  unpin)    cmd_unpin "$@" ;;
  status)   cmd_status "$@" ;;
  list|ls)  cmd_list "$@" ;;
  stop)     cmd_stop "$@" ;;
  cancel)   cmd_cancel "$@" ;;
  clean)    cmd_clean "$@" ;;
  run)      cmd_run "$@" ;;
  attach)   cmd_attach "$@" ;;
  uuid)     cmd_uuid "$@" ;;
  pool)
    pool_cmd="${1:-}"
    shift || true
    case "$pool_cmd" in
      init)    pool_init "$@" ;;
      stop)    pool_stop "$@" ;;
      status)  pool_status "$@" ;;
      resize)  pool_resize "$@" ;;
      list|ls) pool_list "$@" ;;
      destroy) pool_destroy "$@" ;;
      gc)      pool_gc "$@" ;;
      migrate) pool_migrate "$@" ;;
      *)
        echo "sub-claude: unknown pool command: '$pool_cmd'" >&2
        echo "Run 'sub-claude help' for usage." >&2
        exit 1
        ;;
    esac
    ;;
  help|-h|--help|'')
    usage
    ;;
  *)
    echo "sub-claude: unknown command: '$cmd'" >&2
    echo "Run 'sub-claude help' for usage." >&2
    exit 1
    ;;
esac
